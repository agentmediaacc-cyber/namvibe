[Unit]
Description=Gunicorn instance to serve CHAIN (HTTP Mode)
After=network.target redis.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/chain_app
Environment="PATH=/var/www/chain_app/venv/bin"
EnvironmentFile=/var/www/chain_app/.env
ExecStart=/var/www/chain_app/venv/bin/gunicorn app:app --config gunicorn.conf.py --workers 2

[Install]
WantedBy=multi-user.target
