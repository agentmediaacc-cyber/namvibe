{% extends "base.html" %}

{% block title %}Messages | CHAIN{% endblock %}

{% block extra_css %}
<style>
    .chat-layout {
        display: flex;
        height: calc(100vh - 70px);
        background: var(--chain-bg);
    }
    
    .chat-sidebar {
        width: 100%;
        max-width: 400px;
        border-right: 1px solid var(--chain-border);
        display: flex;
        flex-direction: column;
        background: var(--chain-bg-panel);
    }
    
    .sidebar-header {
        padding: 20px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--chain-border);
    }
    
    .sidebar-tabs {
        display: flex;
        padding: 10px 16px;
        gap: 12px;
        overflow-x: auto;
        border-bottom: 1px solid var(--chain-border);
    }
    
    .tab-btn {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        background: var(--chain-bg-soft);
        color: var(--chain-muted);
        white-space: nowrap;
    }
    
    .tab-btn.active {
        background: var(--chain-primary);
        color: white;
    }
    
    .chat-list {
        flex: 1;
        overflow-y: auto;
    }
    
    .chat-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--chain-border);
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
        color: inherit;
    }
    
    .chat-item:hover { background: var(--chain-bg-soft); }
    
    .chat-item.pinned { border-left: 3px solid var(--chain-primary); }
    
    .chat-info { flex: 1; min-width: 0; }
    
    .chat-name-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    
    .chat-name { font-weight: 700; font-size: 15px; }
    
    .chat-time { font-size: 11px; color: var(--chain-muted); }
    
    .chat-preview { 
        font-size: 13px; 
        color: var(--chain-muted); 
        white-space: nowrap; 
        overflow: hidden; 
        text-overflow: ellipsis; 
    }
    
    .unread-badge {
        width: 18px; height: 18px;
        background: var(--chain-primary);
        color: white;
        border-radius: 50%;
        font-size: 10px;
        display: grid;
        place-items: center;
        font-weight: 700;
    }
    
    .search-box {
        margin: 12px 16px;
        background: var(--chain-bg-soft);
        border-radius: 12px;
        display: flex;
        align-items: center;
        padding: 8px 12px;
        border: 1px solid var(--chain-border);
    }
    
    .search-input {
        background: transparent;
        border: none;
        padding: 4px 8px;
        flex: 1;
        outline: none;
        font-size: 14px;
    }

    @media (max-width: 768px) {
        .chat-sidebar { max-width: 100%; }
        .chat-main-placeholder { display: none; }
    }
    
    .chat-main-placeholder {
        flex: 1;
        display: grid;
        place-items: center;
        background: var(--chain-bg-soft);
    }
</style>
{% endblock %}

{% block content %}
<div class="chat-layout">
    <aside class="chat-sidebar">
        <div class="sidebar-header">
            <h1 style="margin:0; font-size: 20px;">Messages</h1>
            <button class="px-btn primary small" onclick="location.href='/discover/'" style="padding: 6px 12px; font-size: 12px;">New Chat</button>
        </div>
        
        <div class="search-box">
            <i class="fas fa-search" style="color: var(--chain-muted);"></i>
            <input type="text" id="chat-search" class="search-input" placeholder="Search messages...">
        </div>
        
        <div class="sidebar-tabs">
            <div class="tab-btn active">All</div>
            <div class="tab-btn">Unread</div>
            <div class="tab-btn">Archived</div>
            <div class="tab-btn">Groups</div>
        </div>
        
        <div class="chat-list" id="chat-list">
            {% if threads %}
                {% for t in threads %}
                <a href="/messages/{{ t.id }}" class="chat-item {{ 'pinned' if t.is_pinned else '' }}">
                    <div class="chat-avatar" style="width: 50px; height: 50px; border-radius: 50%; overflow: hidden; background: var(--chain-bg-soft); flex-shrink: 0;">
                        {% if t.display_avatar %}
                        <img src="{{ t.display_avatar }}" style="width: 100%; height: 100%; object-fit: cover;">
                        {% else %}
                        <div style="width:100%; height:100%; display:grid; place-items:center;"><i class="fas fa-{{ 'users' if t.thread_type == 'group' else 'user' }}"></i></div>
                        {% endif %}
                    </div>
                    <div class="chat-info">
                        <div class="chat-name-row">
                            <span class="chat-name">{{ t.display_name }}</span>
                            <span class="chat-time">{{ t.last_message_at|datetime if t.last_message_at else '' }}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span class="chat-preview">{{ t.last_message or 'No messages' }}</span>
                            {% if t.unread_count > 0 %}
                            <div class="unread-badge">{{ t.unread_count }}</div>
                            {% endif %}
                        </div>
                    </div>
                </a>
                {% endfor %}
            {% else %}
                <div style="padding: 40px; text-align: center; color: var(--chain-muted);">
                    <i class="fas fa-comment-slash fa-3x" style="margin-bottom: 20px; opacity: 0.3;"></i>
                    <p>No conversations yet</p>
                </div>
            {% endif %}
        </div>
    </aside>
    
    <main class="chat-main-placeholder">
        <div style="text-align: center; color: var(--chain-muted);">
            <i class="fas fa-comments fa-4x" style="margin-bottom: 24px; opacity: 0.1;"></i>
            <h3>Your Messages</h3>
            <p>Select a conversation to start chatting</p>
        </div>
    </main>
</div>
{% endblock %}

{% block extra_js %}
<script>
    document.getElementById('chat-search').addEventListener('input', async (e) => {
        const q = e.target.value;
        if (q.length < 2) return;
        
        const res = await fetch(`/messages/api/messages/search?q=${q}`);
        const data = await res.json();
        // Update list with search results
    });
</script>
{% endblock %}
