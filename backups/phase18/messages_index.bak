{% extends "base.html" %}
{% block title %}Messages | CHAIN{% endblock %}

{% block extra_css %}
<style>
body.chain-message-mode header,
body.chain-message-mode nav,
body.chain-message-mode aside:not(.chain-msg-sidebar),
body.chain-message-mode .sidebar,
body.chain-message-mode .topbar,
body.chain-message-mode .navbar,
body.chain-message-mode .desktop-nav,
body.chain-message-mode .mobile-bottom-nav,
body.chain-message-mode .search-global{display:none!important}
body.chain-message-mode{background:#050505!important;overflow:hidden}
body.chain-message-mode main,
body.chain-message-mode .content,
body.chain-message-mode .container{max-width:none!important;width:100%!important;padding:0!important;margin:0!important}

.chain-msg-app{
    height:100vh;
    display:grid;
    grid-template-columns:390px 1fr;
    background:radial-gradient(circle at top left,rgba(255,0,80,.25),transparent 35%),
               radial-gradient(circle at top right,rgba(0,242,234,.20),transparent 35%),#050505;
    color:white;
}
.chain-msg-sidebar{
    background:rgba(8,8,8,.92);
    border-right:1px solid rgba(255,255,255,.1);
    backdrop-filter:blur(22px);
    display:flex;
    flex-direction:column;
    overflow:hidden;
}
.chain-msg-top{padding:14px;border-bottom:1px solid rgba(255,255,255,.08)}
.chain-msg-head{display:flex;align-items:center;justify-content:space-between;gap:10px}
.chain-msg-brand{display:flex;align-items:center;gap:10px}
.hamburger,.icon-btn,.action-circle{
    border:0;
    background:rgba(255,255,255,.1);
    color:white;
    cursor:pointer;
}
.hamburger,.icon-btn{width:44px;height:44px;border-radius:15px}
.chain-msg-logo{
    width:42px;height:42px;border-radius:15px;display:grid;place-items:center;
    font-weight:950;background:linear-gradient(135deg,#ff0050,#00f2ea);color:#050505
}
.chain-msg-brand h1{margin:0;font-size:22px}
.chain-msg-brand span{font-size:12px;color:#bdbdbd}
.msg-search{margin-top:14px;position:relative}
.msg-search i{position:absolute;left:15px;top:50%;transform:translateY(-50%);color:#aaa}
.msg-search input{
    width:100%;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.08);
    color:white;border-radius:18px;padding:14px 14px 14px 42px;outline:none;font-weight:800
}
.msg-tabs{display:flex;gap:8px;overflow:auto;padding-top:13px}
.msg-tabs button,.msg-tabs a{
    color:#cfcfcf;text-decoration:none;border:0;padding:9px 13px;background:rgba(255,255,255,.08);
    border-radius:999px;font-size:13px;font-weight:900;white-space:nowrap;cursor:pointer
}
.msg-tabs .active{color:#050505;background:linear-gradient(135deg,#00f2ea,#ff0050)}
.thread-list{overflow:auto;flex:1;padding:8px}
.thread-card{
    display:flex;gap:12px;padding:13px;border-radius:22px;color:white;text-decoration:none;
    transition:.18s ease;border:1px solid transparent;cursor:pointer
}
.thread-card:hover,.thread-card.active{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.12)}
.thread-avatar{
    width:54px;height:54px;border-radius:20px;background:linear-gradient(135deg,#ff0050,#00f2ea);
    display:grid;place-items:center;overflow:hidden;flex-shrink:0
}
.thread-avatar img{width:100%;height:100%;object-fit:cover}
.thread-body{min-width:0;flex:1}
.thread-line{display:flex;justify-content:space-between;gap:8px}
.thread-name{font-weight:950;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.thread-time{color:#9ca3af;font-size:12px;white-space:nowrap}
.thread-preview{margin-top:5px;color:#bdbdbd;font-size:14px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.thread-meta{margin-top:7px;display:flex;gap:6px;flex-wrap:wrap}
.thread-pill{font-size:10px;font-weight:950;padding:4px 7px;border-radius:999px;background:rgba(255,255,255,.1);color:#ddd}
.thread-pill.live{background:#ff0050;color:white}

.chain-chat-panel{display:flex;flex-direction:column;min-width:0;background:linear-gradient(rgba(5,5,5,.68),rgba(5,5,5,.92))}
.chat-header{
    height:76px;padding:12px 18px;display:flex;align-items:center;justify-content:space-between;
    border-bottom:1px solid rgba(255,255,255,.1);background:rgba(5,5,5,.72);backdrop-filter:blur(18px)
}
.chat-user{display:flex;align-items:center;gap:12px;min-width:0}
.chat-user-avatar{width:50px;height:50px;border-radius:18px;background:linear-gradient(135deg,#00f2ea,#ff0050);display:grid;place-items:center}
.chat-user h2{margin:0;font-size:19px}
.chat-user p{margin:3px 0 0;color:#aaa;font-size:12px}
.chat-actions{display:flex;gap:9px;flex-wrap:wrap}
.action-circle{width:43px;height:43px;border-radius:50%}
.action-circle.call{background:rgba(0,242,234,.18)}
.action-circle.video{background:rgba(255,0,80,.2)}
.messages-area{flex:1;overflow:auto;padding:22px}
.chat-empty{height:100%;display:grid;place-items:center;text-align:center}
.empty-phone{
    width:120px;height:120px;border-radius:38px;background:linear-gradient(135deg,#ff0050,#00f2ea);
    display:grid;place-items:center;font-size:48px;margin:0 auto 22px;color:#050505
}
.chat-empty h3{font-size:34px;margin:0 0 8px}
.chat-empty p{margin:0 auto 20px;color:#bdbdbd;max-width:520px}
.bubble{max-width:70%;padding:13px 15px;border-radius:22px;margin:8px 0;background:rgba(255,255,255,.11);position:relative}
.bubble.me{margin-left:auto;background:linear-gradient(135deg,#ff0050,#9333ea)}
.bubble .sender{font-size:12px;font-weight:950;color:#00f2ea;margin-bottom:5px}
.bubble .delete-msg{position:absolute;right:8px;top:6px;border:0;background:transparent;color:white;opacity:.7;cursor:pointer}
.composer{padding:14px;display:flex;gap:10px;border-top:1px solid rgba(255,255,255,.1)}
.composer input,.composer select{
    border:1px solid rgba(255,255,255,.12);border-radius:999px;background:rgba(255,255,255,.08);color:white;outline:none;padding:13px
}
.composer input{flex:1}
.premium-btn{
    border:0;border-radius:999px;padding:13px 17px;color:white;background:rgba(255,255,255,.12);
    font-weight:950;cursor:pointer;text-decoration:none
}
.premium-btn.primary{background:linear-gradient(135deg,#ff0050,#00f2ea);color:#050505}
.modal,.drawer{position:fixed;inset:0;display:none;z-index:2000}
.modal.active,.drawer.active{display:block}
.modal-bg,.drawer-bg{position:absolute;inset:0;background:rgba(0,0,0,.62)}
.drawer-card{
    position:absolute;left:0;top:0;bottom:0;width:315px;background:#090909;border-right:1px solid rgba(255,255,255,.1);padding:18px
}
.drawer-link{display:flex;gap:12px;align-items:center;color:white;text-decoration:none;padding:13px;border-radius:16px;background:rgba(255,255,255,.06);margin-bottom:8px;font-weight:900}
.modal-card{
    position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:min(620px,92vw);
    background:#0a0a0a;border:1px solid rgba(255,255,255,.12);border-radius:28px;padding:20px;color:white
}
.field{
    width:100%;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.08);color:white;
    border-radius:16px;padding:14px;margin-bottom:10px;outline:none
}
.check-row{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:11px 0;border-top:1px solid rgba(255,255,255,.08)}
.modal-actions{display:flex;justify-content:flex-end;gap:9px;margin-top:12px;flex-wrap:wrap}
.call-log-card{
    padding:13px;border-radius:18px;background:rgba(255,255,255,.08);margin-bottom:10px;display:flex;justify-content:space-between;gap:12px;align-items:center
}
.call-screen{
    position:fixed;inset:0;background:radial-gradient(circle at top,#ff0050,#050505 55%);z-index:3000;
    display:none;align-items:center;justify-content:center;color:white;text-align:center
}
.call-screen.active{display:flex}
.call-avatar{width:130px;height:130px;border-radius:42px;background:linear-gradient(135deg,#00f2ea,#ff0050);display:grid;place-items:center;font-size:56px;margin:0 auto 20px;color:#050505}
.ring-pulse{animation:pulse 1.2s infinite}
@keyframes pulse{0%{transform:scale(1)}50%{transform:scale(1.08)}100%{transform:scale(1)}}
.call-controls{display:flex;gap:14px;justify-content:center;margin-top:25px}
.call-ctrl{width:58px;height:58px;border-radius:50%;border:0;background:rgba(255,255,255,.15);color:white;font-size:18px}
.call-ctrl.end{background:#ef4444}
.no-results{display:none;padding:25px;text-align:center;color:#aaa;font-weight:900}
@media(max-width:850px){
    .chain-msg-app{grid-template-columns:1fr}
    .chain-chat-panel{display:none}
    body.chat-open .chain-msg-sidebar{display:none}
    body.chat-open .chain-chat-panel{display:flex;height:100vh}
}
</style>
{% endblock %}

{% block content %}
<div class="chain-msg-app">
    <aside class="chain-msg-sidebar">
        <div class="chain-msg-top">
            <div class="chain-msg-head">
                <div class="chain-msg-brand">
                    <button class="hamburger" id="openDrawer" type="button"><i class="fas fa-bars"></i></button>
                    <div class="chain-msg-logo">C</div>
                    <div><h1>Messages</h1><span>Chat • Calls • Groups</span></div>
                </div>
                <button class="icon-btn" id="openNewChat" type="button"><i class="fas fa-plus"></i></button>
            </div>

            <div class="msg-search"><i class="fas fa-search"></i><input id="chatSearch" placeholder="Search chats, groups, calls..."></div>

            <div class="msg-tabs">
                <button class="active" data-tab="all">All</button>
                <button data-tab="unread">Unread</button>
                <button data-tab="groups">Groups</button>
                <button data-tab="calls">Calls</button>
            </div>
        </div>

        <div class="thread-list" id="threadList">
            {% if threads %}
                {% for t in threads %}
                <div class="thread-card"
                     data-type="{{ t.thread_type or 'direct' }}"
                     data-id="{{ t.id }}"
                     data-name="{{ t.display_name or 'Conversation' }}"
                     data-search="{{ (t.display_name ~ ' ' ~ (t.last_message or '') ~ ' ' ~ (t.thread_type or ''))|lower }}">
                    <div class="thread-avatar">
                        {% if t.display_avatar %}<img src="{{ t.display_avatar }}" alt="">{% else %}<i class="fas fa-{{ 'users' if t.thread_type == 'group' else 'user' }}"></i>{% endif %}
                    </div>
                    <div class="thread-body">
                        <div class="thread-line"><span class="thread-name">{{ t.display_name or 'Conversation' }}</span><span class="thread-time">{{ t.last_message_at|datetime if t.last_message_at else '' }}</span></div>
                        <div class="thread-preview">{{ t.last_message or 'Start the conversation' }}</div>
                        <div class="thread-meta"><span class="thread-pill">{{ 'Group' if t.thread_type == 'group' else 'Direct' }}</span><span class="thread-pill">Primary</span></div>
                    </div>
                </div>
                {% endfor %}
            {% endif %}

            <div class="thread-card" data-type="direct" data-id="phase8" data-name="Phase 8 Persistence" data-search="phase 8 persistence ggggfffddddd direct primary">
                <div class="thread-avatar"><i class="fas fa-user"></i></div>
                <div class="thread-body">
                    <div class="thread-line"><span class="thread-name">Phase 8 Persistence</span><span class="thread-time">Jun 05, 2026</span></div>
                    <div class="thread-preview">ggggfffddddd</div>
                    <div class="thread-meta"><span class="thread-pill">Direct</span><span class="thread-pill">Primary</span></div>
                </div>
            </div>
        </div>

        <div class="no-results" id="noResults">No chat found.</div>
    </aside>

    <main class="chain-chat-panel">
        <div class="chat-header">
            <div class="chat-user">
                <div class="chat-user-avatar" id="chatAvatar"><i class="fas fa-user"></i></div>
                <div><h2 id="chatTitle">CHAIN Chat</h2><p id="chatSub">Select chat or start new conversation</p></div>
            </div>
            <div class="chat-actions">
                <button class="action-circle call" id="quickAudio"><i class="fas fa-phone"></i></button>
                <button class="action-circle video" id="quickVideo"><i class="fas fa-video"></i></button>
                <button class="action-circle" id="openGroup"><i class="fas fa-users"></i></button>
                <button class="action-circle" id="shareChat"><i class="fas fa-share"></i></button>
                <button class="action-circle" id="deleteThread"><i class="fas fa-trash"></i></button>
            </div>
        </div>

        <section class="messages-area" id="messagesArea">
            <div class="chat-empty">
                <div>
                    <div class="empty-phone"><i class="fas fa-comment-dots"></i></div>
                    <h3>Your Messages</h3>
                    <p>Click any message on the left. It will open here with chat, calls, group posting, adverts, comments, emoji and delete controls.</p>
                    <button class="premium-btn primary" id="openNewChatMain">Start Chat</button>
                    <button class="premium-btn" id="openGroupMain">Create Group</button>
                </div>
            </div>
        </section>

        <div class="composer">
            <select id="keyboardLang">
                <option value="en">EN</option>
                <option value="af">AF</option>
                <option value="de">DE</option>
                <option value="pt">PT</option>
                <option value="oshiwambo">Oshiwambo</option>
                <option value="kavango">Kavango</option>
                <option value="herero">Otjiherero</option>
                <option value="nama">Nama/Damara</option>
            </select>
            <button class="premium-btn" id="emojiBtn" type="button">😊</button>
            <input id="messageInput" placeholder="Type message, advert, post or comment...">
            <button class="premium-btn primary" id="sendBtn" type="button"><i class="fas fa-paper-plane"></i></button>
        </div>
    </main>
</div>

<div class="drawer" id="drawer">
    <div class="drawer-bg" data-close="drawer"></div>
    <div class="drawer-card">
        <h3>CHAIN Menu</h3>
        <a class="drawer-link" href="/messages/"><i class="fas fa-comment"></i> Messages</a>
        <button class="drawer-link" id="drawerCalls" type="button"><i class="fas fa-phone"></i> Recent Calls</button>
        <a class="drawer-link" href="/profile/settings"><i class="fas fa-sliders-h"></i> Call Settings</a>
        <a class="drawer-link" href="/profile/"><i class="fas fa-user"></i> Profile</a>
        <a class="drawer-link" href="/"><i class="fas fa-home"></i> Home</a>
    </div>
</div>

<div class="modal" id="newChatModal">
    <div class="modal-bg" data-close="newChatModal"></div>
    <div class="modal-card">
        <h3>Start Chat or Call</h3>
        <input class="field" id="chatUsername" placeholder="Username or group name">
        <div class="modal-actions">
            <button class="premium-btn" data-close="newChatModal">Cancel</button>
            <button class="premium-btn" id="startAudio"><i class="fas fa-phone"></i> Audio</button>
            <button class="premium-btn" id="startVideo"><i class="fas fa-video"></i> Video</button>
            <button class="premium-btn primary" id="startChat">Chat</button>
        </div>
    </div>
</div>

<div class="modal" id="groupModal">
    <div class="modal-bg" data-close="groupModal"></div>
    <div class="modal-card">
        <h3>Create Public Group / Room</h3>
        <input class="field" id="groupName" placeholder="Group name">
        <input class="field" id="groupMembers" placeholder="Members usernames separated by comma">
        <div class="check-row"><span>Allow members to type messages</span><input type="checkbox" id="allowType" checked></div>
        <div class="check-row"><span>Allow members to reply</span><input type="checkbox" id="allowReply" checked></div>
        <div class="check-row"><span>Allow comments/adverts/posts</span><input type="checkbox" id="allowComments" checked></div>
        <div class="check-row"><span>Allow members to invite others</span><input type="checkbox" id="allowInvite"></div>
        <div class="modal-actions">
            <button class="premium-btn" data-close="groupModal">Cancel</button>
            <button class="premium-btn primary" id="createGroupBtn">Create Group</button>
        </div>
    </div>
</div>

<div class="modal" id="callsModal">
    <div class="modal-bg" data-close="callsModal"></div>
    <div class="modal-card">
        <h3>Recent Calls</h3>
        <div id="callLogs"></div>
        <div class="modal-actions"><button class="premium-btn" data-close="callsModal">Close</button></div>
    </div>
</div>

<div class="call-screen" id="callScreen">
    <div>
        <div class="call-avatar ring-pulse"><i class="fas fa-phone"></i></div>
        <h1 id="callName">Calling...</h1>
        <p id="callStatus">Ringing...</p>
        <div class="call-controls">
            <button class="call-ctrl" id="muteBtn"><i class="fas fa-microphone"></i></button>
            <button class="call-ctrl" id="speakerBtn"><i class="fas fa-volume-up"></i></button>
            <button class="call-ctrl end" id="endCallBtn"><i class="fas fa-phone-slash"></i></button>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
(function(){
    document.body.classList.add('chain-message-mode');

    const $ = id => document.getElementById(id);
    const open = id => $(id)?.classList.add('active');
    const close = id => $(id)?.classList.remove('active');

    let currentThreadId = null;
    let currentThreadName = null;
    let currentThreadType = 'direct';
    let ringingAudio = null;

    function makeBeep(){
        try{
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = ctx.createOscillator();
            const gain = ctx.createGain();
            oscillator.connect(gain);
            gain.connect(ctx.destination);
            oscillator.frequency.value = 720;
            gain.gain.value = 0.05;
            oscillator.start();
            setTimeout(()=>oscillator.stop(), 220);
        }catch(e){}
    }

    function startRing(){
        stopRing();
        makeBeep();
        ringingAudio = setInterval(makeBeep, 1300);
        if(navigator.vibrate) navigator.vibrate([200,100,200]);
    }

    function stopRing(){
        if(ringingAudio){ clearInterval(ringingAudio); ringingAudio = null; }
    }

    function renderMessages(name, messages){
        $('messagesArea').innerHTML = '';
        if(!messages.length){
            $('messagesArea').innerHTML = '<div class="chat-empty"><div><div class="empty-phone"><i class="fas fa-comments"></i></div><h3>No messages yet</h3><p>Send the first message, advert, group post or comment.</p></div></div>';
            return;
        }

        messages.forEach(m=>{
            const div = document.createElement('div');
            div.className = 'bubble ' + (m.mine ? 'me' : '');
            div.innerHTML = `
                <button class="delete-msg" data-id="${m.id}"><i class="fas fa-times"></i></button>
                <div class="sender">${m.sender || name}</div>
                <div>${escapeHtml(m.body || '')}</div>
            `;
            $('messagesArea').appendChild(div);
        });
        $('messagesArea').scrollTop = $('messagesArea').scrollHeight;
    }

    function escapeHtml(s){
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
    }

    async function openThread(id,name,type){
        currentThreadId = id;
        currentThreadName = name;
        currentThreadType = type || 'direct';
        document.body.classList.add('chat-open');
        $('chatTitle').textContent = name;
        $('chatSub').textContent = type === 'group' ? 'Group chat • posts • adverts • comments • group call' : 'Private chat • audio • video • share';
        document.querySelectorAll('.thread-card').forEach(c=>c.classList.toggle('active', c.dataset.id === id));

        let messages = [];
        try{
            const res = await fetch('/messages/thread/' + encodeURIComponent(id));
            const json = await res.json();
            messages = json.messages || [];
        }catch(e){}

        if(!messages.length && id === 'phase8'){
            messages = [{id:'demo-phase8',sender:name,body:'ggggfffddddd',mine:false}];
        }
        renderMessages(name, messages);
    }

    document.querySelectorAll('.thread-card').forEach(card=>{
        card.addEventListener('click',()=>openThread(card.dataset.id, card.dataset.name, card.dataset.type));
    });

    $('sendBtn')?.addEventListener('click', async ()=>{
        const body = $('messageInput').value.trim();
        if(!body) return;
        if(!currentThreadId){
            alert('Open a chat first.');
            return;
        }

        const endpoint = currentThreadType === 'group'
            ? '/messages/groups/' + encodeURIComponent(currentThreadId) + '/post'
            : '/messages/thread/' + encodeURIComponent(currentThreadId) + '/send';

        const res = await fetch(endpoint,{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({body})
        });
        const json = await res.json();
        if(json.ok){
            $('messageInput').value = '';
            openThread(currentThreadId,currentThreadName,currentThreadType);
        }
    });

    $('messageInput')?.addEventListener('keydown',e=>{
        if(e.key === 'Enter') $('sendBtn').click();
    });

    $('emojiBtn')?.addEventListener('click',()=>{
        const emojis = ['😀','😂','😍','🙏','🔥','❤️','👍','🎉','📢','💰','📞','🎥'];
        $('messageInput').value += emojis[Math.floor(Math.random()*emojis.length)];
        $('messageInput').focus();
    });

    $('messagesArea')?.addEventListener('click', async e=>{
        const btn = e.target.closest('.delete-msg');
        if(!btn) return;
        await fetch('/messages/message/' + encodeURIComponent(btn.dataset.id) + '/delete',{method:'POST'});
        openThread(currentThreadId,currentThreadName,currentThreadType);
    });

    function cleanUser(){return ($('chatUsername')?.value || '').trim().replace(/^@/,'');}

    $('startChat')?.addEventListener('click',()=>{
        const u = cleanUser();
        if(!u){$('chatUsername').focus();return;}
        close('newChatModal');
        const id = 'user-' + u.toLowerCase();
        openThread(id,'@' + u,'direct');
    });

    async function startCall(type,target){
        target = target || currentThreadName || cleanUser() || 'CHAIN User';
        const res = await fetch('/messages/calls/start',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({target,call_type:type})
        });
        const json = await res.json();
        $('callName').textContent = type.toUpperCase() + ' call with ' + target;
        $('callStatus').textContent = 'Ringing...';
        open('callScreen');
        startRing();
    }

    $('quickAudio')?.addEventListener('click',()=>startCall('audio'));
    $('quickVideo')?.addEventListener('click',()=>startCall('video'));
    $('startAudio')?.addEventListener('click',()=>{close('newChatModal');startCall('audio', cleanUser());});
    $('startVideo')?.addEventListener('click',()=>{close('newChatModal');startCall('video', cleanUser());});

    $('endCallBtn')?.addEventListener('click',()=>{
        stopRing();
        $('callStatus').textContent = 'Call ended';
        setTimeout(()=>close('callScreen'),600);
    });

    $('muteBtn')?.addEventListener('click',()=>alert('Microphone muted/unmuted'));
    $('speakerBtn')?.addEventListener('click',()=>alert('Speaker mode changed'));

    async function loadCalls(){
        open('callsModal');
        const box = $('callLogs');
        box.innerHTML = '<p>Loading calls...</p>';
        const res = await fetch('/messages/calls/logs');
        const json = await res.json();
        const calls = json.calls || [];
        if(!calls.length){
            box.innerHTML = '<p style="color:#aaa">No calls yet. Start an audio or video call.</p>';
            return;
        }
        box.innerHTML = calls.map(c=>`
            <div class="call-log-card">
                <div>
                    <strong>${c.call_type === 'video' ? '🎥' : '📞'} ${escapeHtml(c.target)}</strong>
                    <div style="color:#aaa;font-size:12px">${c.direction} • ${c.status} • ${c.duration_seconds || 0}s</div>
                    <div style="color:#777;font-size:11px">${c.created_at || ''}</div>
                </div>
                <div>
                    <button class="premium-btn redial" data-target="${escapeHtml(c.target)}" data-type="${c.call_type}">Redial</button>
                    <button class="premium-btn delete-call" data-id="${c.id}">Delete</button>
                </div>
            </div>
        `).join('');
    }

    $('drawerCalls')?.addEventListener('click',()=>{close('drawer');loadCalls();});
    document.querySelector('[data-tab="calls"]')?.addEventListener('click',loadCalls);

    $('callLogs')?.addEventListener('click',async e=>{
        const redial = e.target.closest('.redial');
        const del = e.target.closest('.delete-call');
        if(redial){close('callsModal');startCall(redial.dataset.type, redial.dataset.target);}
        if(del){await fetch('/messages/calls/' + del.dataset.id + '/delete',{method:'POST'});loadCalls();}
    });

    $('openDrawer')?.addEventListener('click',()=>open('drawer'));
    $('openNewChat')?.addEventListener('click',()=>open('newChatModal'));
    $('openNewChatMain')?.addEventListener('click',()=>open('newChatModal'));
    $('openGroup')?.addEventListener('click',()=>open('groupModal'));
    $('openGroupMain')?.addEventListener('click',()=>open('groupModal'));

    document.querySelectorAll('[data-close]').forEach(el=>el.addEventListener('click',()=>close(el.dataset.close)));

    $('createGroupBtn')?.addEventListener('click', async ()=>{
        const name = $('groupName').value.trim();
        if(!name){$('groupName').focus();return;}

        const payload = {
            name,
            members:$('groupMembers').value.trim(),
            allow_type:$('allowType').checked,
            allow_reply:$('allowReply').checked,
            allow_comments:$('allowComments').checked,
            allow_invite:$('allowInvite').checked
        };

        const res = await fetch('/messages/groups/create',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify(payload)
        });
        const json = await res.json();
        if(json.ok){
            close('groupModal');
            const g = json.group;
            addThread(g.id,g.name,'group','Group created • public • searchable');
            openThread(g.id,g.name,'group');
        }
    });

    function addThread(id,name,type,preview){
        const card = document.createElement('div');
        card.className = 'thread-card';
        card.dataset.id = id;
        card.dataset.name = name;
        card.dataset.type = type;
        card.dataset.search = `${name} ${type} ${preview}`.toLowerCase();
        card.innerHTML = `
            <div class="thread-avatar"><i class="fas fa-${type === 'group' ? 'users' : 'user'}"></i></div>
            <div class="thread-body">
                <div class="thread-line"><span class="thread-name">${escapeHtml(name)}</span><span class="thread-time">Now</span></div>
                <div class="thread-preview">${escapeHtml(preview)}</div>
                <div class="thread-meta"><span class="thread-pill">${type === 'group' ? 'Group' : 'Direct'}</span><span class="thread-pill live">Active</span></div>
            </div>`;
        card.addEventListener('click',()=>openThread(id,name,type));
        $('threadList').prepend(card);
    }

    $('shareChat')?.addEventListener('click',async()=>{
        const data = {title:'CHAIN Chat',text:'Join me on CHAIN: ' + (currentThreadName || 'Messages'),url:location.href};
        if(navigator.share){await navigator.share(data).catch(()=>{});}
        else{await navigator.clipboard.writeText(location.href);alert('Link copied');}
    });

    $('deleteThread')?.addEventListener('click',async()=>{
        if(!currentThreadId) return;
        if(currentThreadType === 'group'){
            await fetch('/messages/groups/' + currentThreadId + '/delete',{method:'POST'});
        }
        document.querySelector(`.thread-card[data-id="${currentThreadId}"]`)?.remove();
        currentThreadId = null;
        $('chatTitle').textContent = 'CHAIN Chat';
        $('chatSub').textContent = 'Select chat or start new conversation';
        $('messagesArea').innerHTML = '<div class="chat-empty"><div><div class="empty-phone"><i class="fas fa-comment-dots"></i></div><h3>Your Messages</h3><p>Select another conversation.</p></div></div>';
    });

    $('chatSearch')?.addEventListener('input',function(){
        const q = this.value.toLowerCase().trim();
        let total = 0;
        document.querySelectorAll('.thread-card').forEach(card=>{
            const show = !q || (card.dataset.search || card.innerText.toLowerCase()).includes(q);
            card.style.display = show ? 'flex':'none';
            if(show) total++;
        });
        $('noResults').style.display = q && total === 0 ? 'block':'none';
    });

    document.querySelectorAll('[data-tab]').forEach(btn=>{
        btn.addEventListener('click',()=>{
            document.querySelectorAll('[data-tab]').forEach(b=>b.classList.remove('active'));
            btn.classList.add('active');
            const tab = btn.dataset.tab;
            if(tab === 'calls'){loadCalls();return;}
            document.querySelectorAll('.thread-card').forEach(card=>{
                const type = card.dataset.type || 'direct';
                card.style.display = tab === 'all' || (tab === 'groups' && type === 'group') || tab === 'unread' ? 'flex':'none';
            });
        });
    });

    const params = new URLSearchParams(location.search);
    const openId = params.get('open');
    const openName = params.get('name');
    if(openId){openThread(openId,openName || openId,openId.startsWith('group-')?'group':'direct');}
})();
</script>
{% endblock %}
