.chain-wallpaper-hero,
.chain-wallpaper-auth,
.chain-wallpaper-onboarding,
.chain-wallpaper-profile,
.chain-wallpaper-wallet,
.chain-wallpaper-marketplace,
.chain-wallpaper-admin {
  position: relative;
}

.chain-wallpaper-hero::before,
.chain-wallpaper-auth::before,
.chain-wallpaper-onboarding::before,
.chain-wallpaper-profile::before,
.chain-wallpaper-wallet::before,
.chain-wallpaper-marketplace::before,
.chain-wallpaper-admin::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: -2;
}

.chain-wallpaper-hero::after,
.chain-wallpaper-auth::after,
.chain-wallpaper-onboarding::after,
.chain-wallpaper-profile::after,
.chain-wallpaper-wallet::after,
.chain-wallpaper-marketplace::after,
.chain-wallpaper-admin::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: -1;
  opacity: 0.08;
  background-image:
    linear-gradient(0deg, rgba(255,255,255,0.55) 50%, transparent 50%),
    linear-gradient(90deg, rgba(255,255,255,0.55) 50%, transparent 50%);
  background-size: 3px 3px;
}

.chain-wallpaper-hero::before {
  background:
    radial-gradient(circle at 14% 12%, rgba(239, 119, 136, 0.22), transparent 22%),
    radial-gradient(circle at 84% 18%, rgba(116, 111, 232, 0.18), transparent 22%),
    radial-gradient(circle at 40% 78%, rgba(250, 179, 111, 0.18), transparent 24%),
    linear-gradient(135deg, rgba(255, 243, 236, 0.95), rgba(255, 249, 245, 0.92));
}

.chain-wallpaper-auth::before {
  background:
    radial-gradient(circle at 20% 15%, rgba(235, 107, 122, 0.18), transparent 24%),
    radial-gradient(circle at 80% 18%, rgba(122, 99, 222, 0.16), transparent 24%),
    radial-gradient(circle at 54% 92%, rgba(94, 173, 194, 0.14), transparent 24%),
    linear-gradient(180deg, rgba(255, 248, 244, 0.97), rgba(255, 241, 241, 0.92));
}

.chain-wallpaper-onboarding::before {
  background:
    radial-gradient(circle at 10% 10%, rgba(240, 161, 118, 0.2), transparent 20%),
    radial-gradient(circle at 88% 12%, rgba(129, 112, 229, 0.18), transparent 22%),
    radial-gradient(circle at 45% 80%, rgba(235, 107, 122, 0.16), transparent 24%),
    linear-gradient(180deg, rgba(255, 250, 246, 0.98), rgba(255, 245, 243, 0.92));
}

.chain-wallpaper-profile::before {
  background:
    radial-gradient(circle at 16% 14%, rgba(250, 179, 111, 0.16), transparent 22%),
    radial-gradient(circle at 80% 20%, rgba(122, 99, 222, 0.16), transparent 22%),
    linear-gradient(180deg, rgba(255, 252, 249, 0.98), rgba(255, 243, 241, 0.9));
}

.chain-wallpaper-wallet::before {
  background:
    radial-gradient(circle at 16% 14%, rgba(214, 168, 91, 0.22), transparent 24%),
    radial-gradient(circle at 82% 16%, rgba(122, 99, 222, 0.14), transparent 22%),
    radial-gradient(circle at 60% 70%, rgba(31, 157, 104, 0.1), transparent 22%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(255, 246, 241, 0.92));
}

.chain-wallpaper-marketplace::before {
  background:
    radial-gradient(circle at 15% 12%, rgba(235, 107, 122, 0.16), transparent 22%),
    radial-gradient(circle at 84% 14%, rgba(94, 173, 194, 0.14), transparent 22%),
    radial-gradient(circle at 56% 86%, rgba(122, 99, 222, 0.16), transparent 22%),
    linear-gradient(180deg, rgba(255, 251, 247, 0.98), rgba(255, 245, 242, 0.93));
}

.chain-wallpaper-admin::before {
  background:
    radial-gradient(circle at 18% 14%, rgba(235, 107, 122, 0.12), transparent 24%),
    radial-gradient(circle at 82% 14%, rgba(122, 99, 222, 0.14), transparent 24%),
    radial-gradient(circle at 50% 86%, rgba(214, 168, 91, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(255, 253, 251, 0.99), rgba(255, 246, 241, 0.95));
}
