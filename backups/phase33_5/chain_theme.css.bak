:root {
  --chain-font-sans: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

  --chain-bg: #050505;
  --chain-bg-soft: #0b0b0f;
  --chain-card: #111118;
  --chain-card-2: #1a1a24;
  --chain-text: #ffffff;
  --chain-muted: #a1a1aa;
  --chain-border: rgba(255,255,255,0.10);

  --chain-cyan: #00f2ea;
  --chain-pink: #ff0050;
  --chain-purple: #833ab4;
  --chain-orange: #fd1d1d;
  --chain-gold: #fcb045;

  --chain-gradient: linear-gradient(135deg, #ff0050, #833ab4, #00f2ea);
  --chain-story-ring: conic-gradient(#fcb045, #fd1d1d, #833ab4, #00f2ea, #fcb045);
  --chain-live-gradient: linear-gradient(135deg, #ff0050, #fd1d1d);
  --chain-premium-gradient: linear-gradient(135deg, #fcb045, #ff0050, #833ab4);

  --chain-success: #22c55e;
  --chain-error: #ff0050;
  --chain-warning: #fcb045;

  --chain-shadow-sm: 0 4px 12px rgba(0,0,0,0.3);
  --chain-shadow-md: 0 8px 24px rgba(0,0,0,0.4);
  --chain-shadow-lg: 0 16px 48px rgba(0,0,0,0.5);

  --chain-radius-sm: 12px;
  --chain-radius-md: 16px;
  --chain-radius-lg: 24px;

  --chain-glass-bg: rgba(255,255,255,0.06);
  --chain-glass-border: rgba(255,255,255,0.10);
  --chain-glass-blur: blur(20px);
  --chain-glass-shadow: 0 8px 32px rgba(0,0,0,0.3);
}

* {
  box-sizing: border-box;
}

html {
  color-scheme: dark;
}

body {
  margin: 0;
  min-height: 100vh;
  color: var(--chain-text);
  background: var(--chain-bg);
  font-family: var(--chain-font-sans);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  overflow-x: hidden;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  max-width: 100%;
}

input, select, textarea, button {
  font: inherit;
}

input, select, textarea {
  width: 100%;
  min-height: 48px;
  padding: 12px 14px;
  border-radius: var(--chain-radius-sm);
  border: 1px solid var(--chain-border);
  background: var(--chain-card-2);
  color: var(--chain-text);
  outline: none;
  transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
}

textarea {
  min-height: 110px;
  resize: vertical;
}

input:focus, select:focus, textarea:focus {
  border-color: rgba(0, 242, 234, 0.4);
  box-shadow: 0 0 0 3px rgba(0, 242, 234, 0.1);
  background: var(--chain-card-2);
}

::selection {
  background: rgba(255, 0, 80, 0.3);
  color: #fff;
}

.chain-card {
  background: var(--chain-card);
  border: 1px solid var(--chain-border);
  border-radius: var(--chain-radius-md);
  box-shadow: var(--chain-shadow-sm);
  backdrop-filter: blur(18px);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.chain-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--chain-shadow-md);
  border-color: rgba(131, 58, 180, 0.3);
}

.chain-btn, .primary, .secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 48px;
  padding: 12px 20px;
  border: none;
  border-radius: 999px;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.chain-btn:hover, .primary:hover, .secondary:hover {
  transform: translateY(-2px);
}

.chain-btn-primary, .primary {
  background: var(--chain-gradient);
  color: #fff;
  box-shadow: 0 8px 24px rgba(255, 0, 80, 0.3);
}

.chain-btn-secondary, .secondary {
  background: var(--chain-card-2);
  color: var(--chain-text);
  border: 1px solid var(--chain-border);
}

.chain-btn-danger {
  background: var(--chain-error);
  color: #fff;
  border: none;
}

.chain-btn-ghost {
  background: transparent;
  color: var(--chain-text);
  border: 1px solid var(--chain-border);
}

.chain-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-height: 32px;
  padding: 6px 12px;
  border-radius: 999px;
  background: var(--chain-card-2);
  border: 1px solid var(--chain-border);
  color: var(--chain-text);
  font-size: 12px;
  font-weight: 800;
}

.chain-section {
  max-width: 1200px;
  margin: 0 auto;
  padding: 24px 16px 80px;
}

.chain-empty-state, .empty-card {
  padding: 24px;
  border-radius: var(--chain-radius-md);
  background: var(--chain-card);
  border: 1px solid var(--chain-border);
  color: var(--chain-muted);
  box-shadow: var(--chain-shadow-sm);
}

.chain-shell {
  display: flex;
  min-height: 100vh;
}

.sidebar {
  width: 280px;
  background: var(--chain-card);
  backdrop-filter: blur(24px);
  border-right: 1px solid var(--chain-border);
  box-shadow: 8px 0 28px rgba(0, 0, 0, 0.3);
  height: 100vh;
  position: sticky;
  top: 0;
  display: flex;
  flex-direction: column;
  padding: 24px;
  z-index: 20;
}

.sidebar-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 34px;
  color: var(--chain-text);
}

.sidebar-brand span {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  background: var(--chain-gradient);
  color: #fff;
  display: grid;
  place-items: center;
  font-size: 10px;
  font-weight: 900;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 16px;
  border-radius: 16px;
  color: var(--chain-muted);
  font-weight: 700;
  transition: background 0.2s ease, color 0.2s ease;
}

.sidebar-link:hover, .sidebar-link.active {
  background: rgba(131, 58, 180, 0.15);
  color: var(--chain-text);
}

.sidebar-link i {
  width: 20px;
  font-size: 18px;
}

.main-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.top-header {
  position: sticky;
  top: 0;
  z-index: 18;
  height: 72px;
  background: rgba(5,5,5,0.85);
  backdrop-filter: blur(22px);
  border-bottom: 1px solid var(--chain-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  max-width: 400px;
  min-height: 42px;
  padding: 0 16px;
  border-radius: 999px;
  background: var(--chain-card-2);
  border: 1px solid var(--chain-border);
}

.search-bar input {
  min-height: auto;
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
  color: var(--chain-text);
}

.search-bar input::placeholder {
  color: var(--chain-muted);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 14px;
}

.notif-badge {
  position: relative;
  color: var(--chain-text);
}

.notif-count {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: var(--chain-pink);
  color: #fff;
  font-size: 9px;
  font-weight: 900;
}

.theme-switcher__btn {
  width: 40px;
  height: 40px;
  border: 1px solid var(--chain-border);
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: var(--chain-card-2);
  color: var(--chain-text);
  cursor: pointer;
}

.content-body {
  padding: 24px 0 0;
}

.mobile-nav {
  position: fixed;
  left: 14px;
  right: 14px;
  bottom: max(12px, env(safe-area-inset-bottom));
  display: none;
  justify-content: space-between;
  gap: 8px;
  padding: 10px;
  border-radius: 24px;
  background: rgba(17,17,24,0.96);
  border: 1px solid var(--chain-border);
  box-shadow: var(--chain-shadow-md);
  z-index: 40;
}

.mobile-link {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  color: var(--chain-muted);
  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.mobile-link:hover {
  transform: translateY(-2px);
}

.mobile-link.active {
  background: rgba(255, 0, 80, 0.15);
  color: var(--chain-text);
}

.mobile-link.center-btn {
  width: 56px;
  height: 56px;
  margin-top: -20px;
  color: #fff;
  border-radius: 18px;
  background: var(--chain-gradient);
  box-shadow: 0 8px 24px rgba(255, 0, 80, 0.3);
}

.chain-shell--social {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 0, 80, 0.20), transparent 32%),
    radial-gradient(circle at top right, rgba(0, 242, 234, 0.16), transparent 30%),
    var(--chain-bg);
  color: var(--chain-text);
}

.chain-shell--social .main-container {
  width: 100%;
  margin-left: 0;
  max-width: none;
}

.chain-shell--social .top-header {
  height: auto;
  min-height: 72px;
  display: grid;
  grid-template-columns: 48px auto minmax(220px, 1fr) auto;
  gap: 12px;
  align-items: center;
  padding: 12px clamp(14px, 3vw, 28px);
  border-bottom: 1px solid var(--chain-border);
  background: rgba(5,5,5,0.82);
  backdrop-filter: blur(22px);
}

.social-menu-btn, .social-icon-btn {
  width: 44px;
  height: 44px;
  border: 1px solid var(--chain-border);
  border-radius: 16px;
  display: grid;
  place-items: center;
  background: var(--chain-card-2);
  color: var(--chain-text);
  cursor: pointer;
}

.social-top-brand, .social-drawer__brand {
  color: var(--chain-text);
  text-decoration: none;
  font-weight: 950;
}

.chain-shell--social .search-bar {
  max-width: 720px;
  width: 100%;
  justify-self: center;
  border: 1px solid var(--chain-border);
  background: var(--chain-card-2);
  border-radius: 999px;
  min-height: 42px;
}

.chain-shell--social .search-bar input {
  color: var(--chain-text);
}

.chain-shell--social .header-actions {
  justify-content: flex-end;
}

.chain-shell--social .content-body {
  padding: 0;
}

.social-drawer-backdrop {
  position: fixed;
  inset: 0;
  z-index: 1100;
  background: rgba(0,0,0,0.62);
  opacity: 0;
  transition: opacity .18s ease;
}

.social-drawer-backdrop.is-open {
  opacity: 1;
}

.social-drawer {
  position: fixed;
  inset: 0 auto 0 0;
  z-index: 1200;
  width: min(340px, 88vw);
  transform: translateX(-102%);
  transition: transform .2s ease;
  border-right: 1px solid var(--chain-border);
  background: rgba(7,7,7,0.96);
  backdrop-filter: blur(24px);
  padding: 16px;
}

.social-drawer.is-open {
  transform: translateX(0);
}

.social-drawer__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.social-drawer__nav {
  display: grid;
  gap: 8px;
}

.social-drawer__nav a {
  display: flex;
  align-items: center;
  gap: 12px;
  min-height: 48px;
  padding: 0 14px;
  border-radius: 16px;
  color: var(--chain-text);
  text-decoration: none;
  font-weight: 850;
  background: var(--chain-card);
}

.social-drawer__nav a:hover {
  background: linear-gradient(135deg, rgba(255,0,80,0.35), rgba(0,242,234,0.25));
}

.chain-shell--social .mobile-nav {
  border-top: 1px solid var(--chain-border);
  background: rgba(5,5,5,0.86);
  backdrop-filter: blur(20px);
}

.app-floating-create {
  position: fixed;
  right: max(18px, env(safe-area-inset-right));
  bottom: calc(92px + env(safe-area-inset-bottom));
  z-index: 42;
  width: 56px;
  height: 56px;
  border-radius: 20px;
  display: none;
  place-items: center;
  background: var(--chain-gradient);
  color: #fff;
  box-shadow: 0 8px 24px rgba(255, 0, 80, 0.3);
  transition: transform .2s ease, box-shadow .2s ease;
}

.chain-home-page .app-floating-create {
  display: none !important;
}

@media (max-width: 1024px) {
  .sidebar { display: none; }
  .mobile-nav { display: flex; }
  .app-floating-create { display: grid; }
}

@media (max-width: 760px) {
  .chain-shell--social .top-header {
    grid-template-columns: 44px auto 44px 44px;
    gap: 8px;
  }
  .chain-shell--social .search-bar { display: none; }
  .chain-shell--social .header-actions .chain-pill,
  .chain-shell--social .header-actions .theme-switcher { display: none; }
  .chain-shell--social .header-actions { display: contents; }
  .chain-shell--social .notif-badge,
  .chain-shell--social .user-profile,
  .chain-shell--social .primary { justify-self: end; }
  .top-header { padding: 0 14px; }
  .search-bar { max-width: none; padding: 0 12px; }
  .content-body { padding-top: 18px; }
}
